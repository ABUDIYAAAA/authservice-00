APP_ENV=development
PORT=8080

API_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kael
REDIS_URL=redis://localhost:6379


# JWT Keys (absolute or relative paths)
ACCESS_TOKEN_PRIVATE_KEY_PATH=keys/access-private.pem
ACCESS_TOKEN_PUBLIC_KEY_PATH=keys/access-public.pem
REFRESH_TOKEN_PRIVATE_KEY_PATH=keys/refresh-private.pem
REFRESH_TOKEN_PUBLIC_KEY_PATH=keys/refresh-public.pem

# Token TTL
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# OAuth - Google
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:8080/api/oauth/google/callback

# OAuth - GitHub
GITHUB_CLIENT_ID=replace-with-github-client-id
GITHUB_CLIENT_SECRET=replace-with-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:8080/api/oauth/github/callback

# SMTP (Mail)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=replace-with-smtp-user
SMTP_PASS=replace-with-smtp-pass
SMTP_FROM=no-reply@example.com

# Cookies
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Sessions & Security
SESSION_TTL_DAYS=7
BCRYPT_SALT_ROUNDS=10
OAUTH_CLIENT_SECRET_ENCRYPTION_KEY=replace-with-base64-secret
OAUTH_STATE_TTL_SECONDS=300
OAUTH_RELOGIN_REQUIREMENT_TTL_SECONDS=86400
OAUTH_RELOGIN_CHALLENGE_TTL_SECONDS=180

PG_POOL_MAX=20
PG_POOL_MIN=0
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONNECTION_TIMEOUT_MS=5000
PG_POOL_MAX_USES=7500
