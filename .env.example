# Server Configuration
PORT=8080
APP_ENV=development
API_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:3000

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/dbname?sslmode=disable
MAX_CONNS=20
MIN_CONNS=5
MAX_CONN_LIFETIME=1h
MAX_CONN_IDLE_TIME=15m
HEALTH_CHECK_PERIOD=1m
CONNECT_TIMEOUT=10s

# Redis Configuration
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=

# Session Configuration
SESSION_COOKIE_NAME=kael_session
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
SESSION_TTL=24h
SESSION_REFRESH_TTL=24h
SESSION_IDLE_TTL=30m

# Security Configuration
BCRYPT_COST=12
TOTP_ENCRYPTION_KEY=your-32-byte-base64-key-here
EMAIL_OTP_TTL=10m

# OAuth Configuration
OAUTH_AUTO_LINK=true
OAUTH_STATE_TTL=10m
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Kael
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_USE_TLS=true

# Background Tasks
ASYNQ_WORKER_CONCURRENCY=10

# Rate Limiting
AUTH_RATE_LIMIT_PER_MINUTE=120
LOGIN_RATE_LIMIT_PER_MINUTE=20
MFA_RATE_LIMIT_PER_MINUTE=30

# OIDC Configuration
OIDC_SIGNING_KEY=your-32-byte-base64-key-here
OIDC_CODE_TTL=5m
OIDC_ACCESS_TOKEN_TTL=1h
OIDC_REFRESH_TOKEN_TTL=720h
OIDC_ISSUER=http://localhost:8080
